rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/fichas/{fichaId} {
      // Só o próprio utilizador autenticado pode ler/escrever as suas fichas.
      allow read: if request.auth != null && request.auth.uid == userId;

      // Na escrita, exige-se ainda que o campo "nome" exista e não esteja vazio,
      // e limita-se o tamanho do documento para evitar abuso.
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.data.nome is string
                   && request.resource.data.nome.size() > 0
                   && request.resource.data.nome.size() < 200;
    }
  }
}
