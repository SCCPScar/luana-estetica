rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.uid == "UbefpX4TALPJk3eXs3CKJMXiEaC2";
    }

    function isLinkedClient(adminId, fichaId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/clientes/$(request.auth.uid))
        && get(/databases/$(database)/documents/clientes/$(request.auth.uid)).data.adminUid == adminId
        && get(/databases/$(database)/documents/clientes/$(request.auth.uid)).data.fichaId == fichaId;
    }

    match /users/{adminId}/fichas/{fichaId} {
      allow read, write: if isAdmin() && request.auth.uid == adminId;
      allow read: if isLinkedClient(adminId, fichaId);
      allow update: if isLinkedClient(adminId, fichaId)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['telefone', 'email', 'endereco', 'updatedAt']);
    }

    match /convites/{codigo} {
      allow get: if request.auth != null;
      allow create: if isAdmin() && request.resource.data.adminUid == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.used == false
        && request.resource.data.used == true
        && request.resource.data.adminUid == resource.data.adminUid
        && request.resource.data.fichaId == resource.data.fichaId;
      allow delete: if isAdmin();
    }

    match /clientes/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid
        && exists(/databases/$(database)/documents/convites/$(request.resource.data.codigoUsado))
        && get(/databases/$(database)/documents/convites/$(request.resource.data.codigoUsado)).data.used == false
        && get(/databases/$(database)/documents/convites/$(request.resource.data.codigoUsado)).data.fichaId == request.resource.data.fichaId
        && get(/databases/$(database)/documents/convites/$(request.resource.data.codigoUsado)).data.adminUid == request.resource.data.adminUid;
      allow delete: if isAdmin();
    }

  }
}
